# ============================================================================
# ENVIRONMENT CONFIGURATION EXAMPLE FILE
# ============================================================================
# Copy this file to .env and fill in your own values
# This file contains all required environment variables for the Flight Booking API
# DO NOT commit the actual .env file to version control
# ============================================================================

# SERVER CONFIGURATION
# The port number that the Express server will listen on
# Default: 5000 if not specified
PORT=5000

# DATABASE CONFIGURATION
# MongoDB connection URI (connection string)
# Format: mongodb://[username:password@]host[:port]/database
# 
# Examples:
# - Local development: mongodb://127.0.0.1:27017/flight-booking
# - MongoDB Atlas cloud: mongodb+srv://username:password@cluster.mongodb.net/flight-booking
MONGO_URI=mongodb://127.0.0.1:27017/flight-booking

# JWT AUTHENTICATION
# Secret key used to sign and verify JWT tokens
# This must be a long, random, secure string
# IMPORTANT: Change this to a strong secret in production!
# Keep this value secret - never share or commit it
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# EMAIL CONFIGURATION (Mailtrap)
# Settings for sending verification emails using Mailtrap
# Mailtrap is an email testing/staging service (https://mailtrap.io)
# For production, replace with SendGrid, Gmail, AWS SES, or other email service

# SMTP server host (email server address)
# For Mailtrap: sandbox.smtp.mailtrap.io
MAIL_HOST=sandbox.smtp.mailtrap.io

# SMTP server port (email server port number)
# 587 = TLS (recommended, used with secure: false in code)
# 465 = SSL (older, less common, used with secure: true in code)
# 25 = Unencrypted (not recommended, don't use in production)
MAIL_PORT=587

# SMTP username (authentication email/username)
# For Mailtrap: get this from your Mailtrap inbox settings
MAIL_USER=your_mailtrap_inbox_username

# SMTP password (authentication password)
# For Mailtrap: get this from your Mailtrap inbox settings
# IMPORTANT: Keep this secret in production!
MAIL_PASS=your_mailtrap_inbox_password
